<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ForgetPasswordFragment">

    <!-- TODO: Update blank fragment layout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/H1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_constraintBottom_toTopOf="@+id/etForgotPassword"
            android:layout_constraintEnd_toEndOf="parent"
            android:layout_constraintStart_toStartOf="parent"
            android:layout_constraintTop_toTopOf="parent"
            android:text="Device Usage"
            android:textSize="50sp"
            tools:layout_editor_absoluteX="43dp"
            tools:layout_editor_absoluteY="67dp" />

        <EditText
            android:id="@+id/etForgotPassword"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_constraintBottom_toTopOf="@+id/btnResetPassword"
            android:layout_constraintTop_toBottomOf="@+id/H1"
            android:layout_constraintEnd_toEndOf="parent"
            android:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="51dp"
            android:ems="10"
            android:hint="enter email to reset"
            android:inputType="textEmailAddress" />

        <Button
            android:id="@+id/btnResetPassword"
            android:layout_width="252dp"
            android:layout_height="0dp"
            android:layout_constraintTop_toBottomOf="@+id/etForgotPassword"
            android:layout_constraintBottom_toBottomOf="parent"
            android:layout_constraintEnd_toEndOf="parent"
            android:layout_constraintStart_toStartOf="parent"
            android:backgroundTint="#6F7F8F"
            android:text="RESET"
            tools:layout_editor_absoluteX="79dp"
            tools:layout_editor_absoluteY="453dp" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>